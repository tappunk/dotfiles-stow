#!/bin/sh

msg_file="$1"

if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
  printf '%s\n' "commit-msg hook error: missing commit message file" >&2
  exit 1
fi

first_line=$(sed -n '1p' "$msg_file")

if [ -z "$first_line" ]; then
  printf '%s\n' "invalid commit message: subject line is empty" >&2
  exit 1
fi

case "$first_line" in
  Merge\ *|Revert\ *|fixup\!*|squash\!*)
    exit 0
    ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9][a-z0-9._/-]*\))?(!)?: [a-z].+$'

if ! printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
  printf '%s\n' "invalid commit message format" >&2
  printf '%s\n' "expected: type(scope)?: subject" >&2
  printf '%s\n' "allowed types: feat fix docs style refactor perf test build ci chore revert" >&2
  printf '%s\n' "example: feat(cli): add json output" >&2
  exit 1
fi

subject_part=${first_line#*: }
subject_len=${#subject_part}

if [ "$subject_len" -gt 72 ]; then
  printf '%s\n' "invalid commit message: subject must be <= 72 characters" >&2
  exit 1
fi

case "$subject_part" in
  *.)
    printf '%s\n' "invalid commit message: subject must not end with a period" >&2
    exit 1
    ;;
esac

exit 0
